# -----------------------------------------------------------------------------
# Grok Agent Orchestra — example environment.
#
# Copy to `.env` and fill in real values. Never commit `.env`.
# `docker compose up` reads this file via `env_file` (and the file is optional
# — compose will warn but not fail if it doesn't exist).
# -----------------------------------------------------------------------------

# ── xAI / Grok ────────────────────────────────────────────────────────────────
# Required for live runs (anything that actually calls Grok).
# Simulated runs (`--dry-run` or the dashboard's "Simulated" toggle) work
# without this key.
XAI_API_KEY=

# ── Orchestra mode selector ──────────────────────────────────────────────────
# native     → use xAI native multi-agent model (grok-4.20-multi-agent-0309)
# simulated  → use prompt-simulated named-role debate (Grok / Harper / Benjamin / Lucas)
# auto       → pick native when available, fall back to simulated
ORCHESTRA_MODE=auto

# ── Logging ──────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR. The CLI's `--log-level` flag overrides this.
LOG_LEVEL=INFO

# ── Optional adapter providers ───────────────────────────────────────────────
# Reserved for the provider-adapter layer on the roadmap. Today these are
# unused; the placeholder keys document the intended escape hatch.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── X (Twitter) deploy target ────────────────────────────────────────────────
# Only required if you flip `deploy.post_to_x: true` on a template. Bridge's
# deploy layer reads these.
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=

# ── Web UI ────────────────────────────────────────────────────────────────────
# Inside the container, defaults to 0.0.0.0:8000 (set by the Dockerfile CMD).
# Override on the host via the compose `ports:` directive — these are here for
# documentation / future extensibility.
# ORCHESTRA_HOST=0.0.0.0
# ORCHESTRA_PORT=8000

# ── Observability (optional) ─────────────────────────────────────────────────
# Tracing is OFF by default — the framework ships with a zero-overhead
# NoOpTracer. Set ONE of the following to enable a backend. All fields are
# read from the environment at startup; raw values never appear in logs.
#
# LangSmith (primary):
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=grok-agent-orchestra
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_SAMPLE_RATE=1.0   # 0.0–1.0; 1.0 = trace every run
#
# Generic OTLP collector (open-source backends like Jaeger / Tempo / Honeycomb):
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=        # comma-sep "k=v" pairs
# OTEL_SERVICE_NAME=grok-agent-orchestra

# ── Inline image generation in reports (optional) ────────────────────────────
# Set the credential for whichever provider your YAML pins under
# `publisher.images.provider`. The framework never embeds a key.
# - Grok image API isn't publicly available yet — use Flux instead.
# - Flux via Replicate (default fallback): https://replicate.com/account/api-tokens
# REPLICATE_API_TOKEN=
# - Stable Diffusion via Stability AI (skeleton only today):
# STABILITY_API_KEY=
