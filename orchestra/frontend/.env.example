# --------------------------------------------------------------------------- #
# Public env vars (visible to the browser bundle). Keep secret-grade
# values out of NEXT_PUBLIC_* — they belong in the FastAPI process
# environment instead.
# --------------------------------------------------------------------------- #

# Public origin of the FastAPI backend. In dev with the two services
# running on different ports, set this to the FastAPI port.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional override for the WebSocket origin. Defaults to the API URL
# with the protocol swapped to ws[s]://.
# NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Public site name shown in the header.
NEXT_PUBLIC_SITE_NAME=Agent Orchestra

# Public site URL — used for canonical links + Open Graph tags.
NEXT_PUBLIC_SITE_URL=https://agent-orchestra.local

# --------------------------------------------------------------------------- #
# Optional auth gate. When the BACKEND has GROK_ORCHESTRA_AUTH_PASSWORD
# set, also set NEXT_PUBLIC_AUTH_REQUIRED=true so the Next.js middleware
# redirects unauthenticated users to /login. Off by default —
# local development never sees the auth UI.
# --------------------------------------------------------------------------- #

# NEXT_PUBLIC_AUTH_REQUIRED=true

# --------------------------------------------------------------------------- #
# Optional Sentry error reporting. Both keys must be set for Sentry to
# initialise; missing either leaves Sentry uninitialised.
# --------------------------------------------------------------------------- #

# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# --------------------------------------------------------------------------- #
# Build-time toggles.
# --------------------------------------------------------------------------- #

# Activate next-bundle-analyzer on the next build:
#   ANALYZE=true pnpm build
# ANALYZE=false
