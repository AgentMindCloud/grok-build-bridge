{
  "name": "grok-orchestra-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Next.js 14 dashboard for grok-agent-orchestra — courtroom debate viz, optional auth, deploy-ready.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "build:export": "NEXT_BUILD_TARGET=export next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:types": "openapi-typescript $NEXT_PUBLIC_API_URL/openapi.json --output types/api.generated.ts",
    "capture:demo": "node ../scripts/capture-demo.mjs"
  },
  "dependencies": {
    "next": "^14.2.5",
    "next-themes": "^0.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "swr": "^2.2.5",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-tooltip": "^1.1.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.5.4",
    "lucide-react": "^0.468.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.5",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "happy-dom": "^15.0.0",
    "openapi-typescript": "^7.4.0",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "packageManager": "pnpm@9.10.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
