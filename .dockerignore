# .dockerignore — keep the build context lean and secrets out of the image.
# Anything matched here is invisible to `COPY` in the Dockerfile.

# --- Version control ---------------------------------------------------------
.git/
.github/
.gitignore
.gitattributes

# --- Python build / install artifacts ----------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
*.whl
build/
dist/
.eggs/
pip-wheel-metadata/

# --- Virtual envs (host's; the image has its own /opt/venv) ------------------
.venv/
.venv*/
venv/
env/
.python-version

# --- Test / coverage / type-check / lint caches ------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.hypothesis/
.coverage
.coverage.*
coverage.xml
htmlcov/

# --- Editor / IDE / OS junk --------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Secrets — NEVER bake these into the image ------------------------------
.env
.env.*
!.env.example

# --- Docker meta (avoid recursive copies) -----------------------------------
Dockerfile
docker-compose.yml
docker-compose.*.yml
.dockerignore

# --- Misc --------------------------------------------------------------------
*.log
docs/_build/
node_modules/
