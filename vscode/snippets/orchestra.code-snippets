{
  "Orchestra — minimal valid spec": {
    "prefix": "orch-min",
    "scope": "yaml",
    "description": "Smallest possible Orchestra spec: a goal and an orchestra block with default mode.",
    "body": [
      "name: ${1:my-orchestra}",
      "goal: \"${2:Draft a tweet about today's xAI launch.}\"",
      "",
      "orchestra:",
      "  mode: ${3|auto,native,simulated|}",
      "",
      "safety:",
      "  lucas_veto_enabled: true",
      "",
      "deploy:",
      "  target: stdout",
      "  post_to_x: false",
      "$0"
    ]
  },
  "Orchestra — native, 4 agents": {
    "prefix": "orch-native-4",
    "scope": "yaml",
    "description": "xAI-native multi-agent spec with 4 agents (baseline cost).",
    "body": [
      "name: ${1:native-4}",
      "goal: \"${2:Describe today's most-discussed xAI topic in one tweet.}\"",
      "",
      "orchestra:",
      "  mode: native",
      "  agent_count: 4",
      "  reasoning_effort: medium",
      "  include_verbose_streaming: true",
      "  orchestration:",
      "    pattern: native",
      "",
      "safety:",
      "  lucas_veto_enabled: true",
      "  confidence_threshold: 0.75",
      "  max_veto_retries: 1",
      "",
      "deploy:",
      "  target: stdout",
      "  post_to_x: false",
      "$0"
    ]
  },
  "Orchestra — native, 16 agents": {
    "prefix": "orch-native-16",
    "scope": "yaml",
    "description": "xAI-native multi-agent spec with 16 agents (~4x the cost of 4-agent; higher quality).",
    "body": [
      "name: ${1:native-16}",
      "goal: \"${2:Research and draft a concise take on a contested topic.}\"",
      "",
      "orchestra:",
      "  mode: native",
      "  agent_count: 16",
      "  reasoning_effort: high",
      "  include_verbose_streaming: true",
      "  orchestration:",
      "    pattern: native",
      "    fallback_on_rate_limit:",
      "      enabled: true",
      "      fallback_model: grok-4.20-0309",
      "      lowered_effort: medium",
      "",
      "safety:",
      "  lucas_veto_enabled: true",
      "  confidence_threshold: 0.85",
      "  max_veto_retries: 1",
      "",
      "deploy:",
      "  target: stdout",
      "  post_to_x: false",
      "$0"
    ]
  },
  "Orchestra — simulated (4-role debate)": {
    "prefix": "orch-simulated",
    "scope": "yaml",
    "description": "Visible Grok / Harper / Benjamin / Lucas debate on grok-4.20-0309.",
    "body": [
      "name: ${1:visible-debate}",
      "goal: \"${2:Debate and draft a tweet about a contested topic.}\"",
      "",
      "orchestra:",
      "  mode: simulated",
      "  debate_rounds: ${3:2}",
      "  debate_style: prompt-simulated",
      "  include_verbose_streaming: true",
      "  orchestration:",
      "    pattern: native",
      "  agents:",
      "    - {name: Grok,     role: coordinator}",
      "    - {name: Harper,   role: researcher}",
      "    - {name: Benjamin, role: logician}",
      "    - {name: Lucas,    role: contrarian}",
      "",
      "safety:",
      "  lucas_veto_enabled: true",
      "  confidence_threshold: 0.75",
      "  max_veto_retries: 1",
      "",
      "deploy:",
      "  target: stdout",
      "  post_to_x: false",
      "$0"
    ]
  },
  "Orchestra — hierarchical pattern": {
    "prefix": "orch-hierarchical",
    "scope": "yaml",
    "description": "Two-team pattern: ResearchTeam (Harper + Benjamin) → CritiqueTeam (Lucas + Grok) → synthesis.",
    "body": [
      "name: ${1:hierarchical-run}",
      "goal: \"${2:Produce a considered short essay with research + critique.}\"",
      "",
      "orchestra:",
      "  mode: simulated",
      "  debate_rounds: 1",
      "  include_verbose_streaming: true",
      "  orchestration:",
      "    pattern: hierarchical",
      "    config: {}",
      "  agents:",
      "    - {name: Harper,   role: researcher}",
      "    - {name: Benjamin, role: logician}",
      "    - {name: Lucas,    role: contrarian}",
      "    - {name: Grok,     role: coordinator}",
      "",
      "safety:",
      "  lucas_veto_enabled: true",
      "  confidence_threshold: 0.75",
      "  max_veto_retries: 1",
      "",
      "deploy:",
      "  target: stdout",
      "  post_to_x: false",
      "$0"
    ]
  },
  "Orchestra — dynamic-spawn pattern": {
    "prefix": "orch-dynamic-spawn",
    "scope": "yaml",
    "description": "Decompose the goal into N sub-tasks, fan out concurrent Harper + Lucas mini-debates, then aggregate.",
    "body": [
      "name: ${1:dynamic-spawn-run}",
      "goal: \"${2:Plan a multi-angle analysis by splitting the goal into sub-tasks.}\"",
      "",
      "orchestra:",
      "  mode: simulated",
      "  include_verbose_streaming: true",
      "  orchestration:",
      "    pattern: dynamic-spawn",
      "    config:",
      "      sub_tasks: ${3:3}",
      "",
      "safety:",
      "  lucas_veto_enabled: true",
      "  confidence_threshold: 0.75",
      "  max_veto_retries: 1",
      "",
      "deploy:",
      "  target: stdout",
      "  post_to_x: false",
      "$0"
    ]
  },
  "Orchestra — debate-loop pattern": {
    "prefix": "orch-debate-loop",
    "scope": "yaml",
    "description": "Iterate rounds with mid-loop Lucas veto + structured consensus check. Early-exits on consensus.",
    "body": [
      "name: ${1:debate-loop-run}",
      "goal: \"${2:Iterate toward a polished, consensus-worthy post.}\"",
      "",
      "orchestra:",
      "  mode: simulated",
      "  include_verbose_streaming: true",
      "  orchestration:",
      "    pattern: debate-loop",
      "    config:",
      "      iterations: ${3:3}",
      "      consensus_threshold: ${4:0.75}",
      "",
      "safety:",
      "  lucas_veto_enabled: true",
      "  confidence_threshold: 0.75",
      "  max_veto_retries: 1",
      "",
      "deploy:",
      "  target: stdout",
      "  post_to_x: false",
      "$0"
    ]
  },
  "Orchestra — parallel-tools pattern": {
    "prefix": "orch-parallel-tools",
    "scope": "yaml",
    "description": "Native multi-agent run with explicit per-agent tool routing; warns on off-list tool usage.",
    "body": [
      "name: ${1:parallel-tools-run}",
      "goal: \"${2:Run native multi-agent with explicit per-agent tool allowlists.}\"",
      "",
      "orchestra:",
      "  mode: native",
      "  agent_count: 4",
      "  reasoning_effort: medium",
      "  include_verbose_streaming: true",
      "  orchestration:",
      "    pattern: parallel-tools",
      "  tool_routing:",
      "    Grok:     []",
      "    Harper:   [web_search, x_search]",
      "    Benjamin: []",
      "    Lucas:    []",
      "",
      "safety:",
      "  lucas_veto_enabled: true",
      "  confidence_threshold: 0.75",
      "  max_veto_retries: 1",
      "",
      "deploy:",
      "  target: stdout",
      "  post_to_x: false",
      "$0"
    ]
  },
  "Orchestra — recovery wrap": {
    "prefix": "orch-recovery",
    "scope": "yaml",
    "description": "Wrap a pattern with degraded-retry recovery: on RateLimitError / ToolExecutionError / TimeoutError, lower effort + fallback model, retry once.",
    "body": [
      "name: ${1:recovery-run}",
      "goal: \"${2:Ship this post even when the API is saturated.}\"",
      "",
      "orchestra:",
      "  mode: native",
      "  agent_count: 16",
      "  reasoning_effort: high",
      "  include_verbose_streaming: true",
      "  orchestration:",
      "    pattern: recovery",
      "    config: {}",
      "    fallback_on_rate_limit:",
      "      enabled: true",
      "      fallback_model: grok-4.20-0309",
      "      lowered_effort: ${3|low,medium|}",
      "",
      "safety:",
      "  lucas_veto_enabled: true",
      "  confidence_threshold: 0.75",
      "  max_veto_retries: 1",
      "",
      "deploy:",
      "  target: stdout",
      "  post_to_x: false",
      "$0"
    ]
  },
  "Orchestra — combined Bridge + Orchestra": {
    "prefix": "orch-combined",
    "scope": "yaml",
    "description": "Single YAML that drives Bridge code generation → Orchestra debate → Lucas veto → deploy.",
    "body": [
      "name: ${1:combined-run}",
      "goal: \"${2:Build a small module and post about its design.}\"",
      "",
      "combined: true",
      "",
      "build:",
      "  name: ${3:my_module}",
      "  target: python",
      "  files:",
      "    - path: ${3:my_module}/__init__.py",
      "      template: |",
      "        \"\"\"${4:Module docstring.}\"\"\"",
      "",
      "        def hello() -> str:",
      "            return \"hello\"",
      "",
      "orchestra:",
      "  mode: simulated",
      "  debate_rounds: 1",
      "  include_verbose_streaming: true",
      "  orchestration:",
      "    pattern: native",
      "  agents:",
      "    - {name: Grok,     role: coordinator}",
      "    - {name: Harper,   role: researcher}",
      "    - {name: Benjamin, role: logician}",
      "    - {name: Lucas,    role: contrarian}",
      "",
      "safety:",
      "  lucas_veto_enabled: true",
      "  confidence_threshold: 0.75",
      "  max_veto_retries: 0",
      "",
      "deploy:",
      "  target: stdout",
      "  post_to_x: false",
      "$0"
    ]
  }
}
