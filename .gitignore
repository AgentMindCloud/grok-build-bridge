# Workspace — test runs, image cache, web cache. Never commit.
workspace/

# Next.js build artefacts (also covered in frontend/.gitignore)
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/types/api.generated.ts

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.eggs/
build/
dist/
wheels/
MANIFEST

# Virtual envs
.venv/
venv/
env/
.python-version

# Tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.hypothesis/

# Editors / OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Env / secrets
.env
.env.*
!.env.example

# Orchestra runtime artefacts
.orchestra/
logs/
*.log

# MkDocs local build output
/site/
